# Root repo hygiene for combined frontend/backend/mobile project

# OS and editor
.DS_Store
Thumbs.db

# Secrets and env files
**/.env
**/.env.*
!**/.env.example

# Python
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Node / web
**/node_modules/
**/.next/
**/dist/
**/build/
**/.pnpm-store/
**/.pnpm-debug.log*
**/*.tsbuildinfo

# Expo / React Native
**/.expo/
**/web-build/
**/android/
**/ios/

# Generated env typings
frontend/next-env.d.ts
StMS/expo-env.d.ts

# Local artifacts
*.log
*.pem
*.orig.*

.claude/
.planning/
CLAUDE.md
