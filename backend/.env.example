# Backend environment example
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mms_db

DATABASE_URL=postgresql+asyncpg://admin:change-me@db:5432/mms_db
JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=10080
INTERNAL_JOB_TOKEN=change-me

RESEND_API_KEY=your_resend_key
EMAIL_FROM=Subscriptions <noreply@example.com>
EMAIL_TO_OVERRIDE=

REDIS_URL=redis://redis:6379/0
CACHE_USER_TTL=600
CACHE_LIST_TTL=60
CACHE_ANALYTICS_TTL=120
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

TZ=Asia/Tokyo


